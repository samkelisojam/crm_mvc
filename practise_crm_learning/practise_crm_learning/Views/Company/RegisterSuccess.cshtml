@{
    ViewData["Title"] = "Registration Successful";
}

<section class="page-hero" style="padding:120px 0;">
    <div class="container">
        <div style="max-width:540px;margin:0 auto;text-align:center;">
            <div style="width:80px;height:80px;background:rgba(0,122,77,0.2);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 24px;font-size:2.5rem;color:var(--sa-green);border:2px solid rgba(0,122,77,0.4);">
                <i class="fa-solid fa-circle-check"></i>
            </div>
            <div class="hero-badge mx-auto d-inline-flex mb-3">
                <i class="fa-solid fa-leaf"></i> Welcome to UbuntuCRM!
            </div>
            <h1 class="section-title">Your Company is Registered!</h1>
            <p style="color:rgba(255,255,255,0.7);font-size:1rem;line-height:1.7;margin-bottom:32px;">
                We've sent a verification email to your inbox. Click the link to activate your account and start using your CRM.
            </p>
            <div class="sa-flag-bar" style="width:80px;margin:0 auto 32px;"></div>
            <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
                <a asp-controller="Crm" asp-action="Dashboard" class="btn-hero-primary">
                    <i class="fa-solid fa-gauge-high"></i> Go to Dashboard
                </a>
                <a asp-controller="Home" asp-action="Index" class="btn-hero-secondary">
                    <i class="fa-solid fa-home"></i> Back to Home
                </a>
            </div>
        </div>
    </div>
</section>
