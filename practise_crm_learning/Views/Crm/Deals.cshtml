@using practise_crm_learning.Models
@model List<Deal>
@{
    ViewData["Title"] = "Deals Pipeline";
    var stages = new[] { DealStage.Prospecting, DealStage.Qualification, DealStage.Proposal, DealStage.Negotiation, DealStage.ClosedWon, DealStage.ClosedLost };
    var stageColors = new Dictionary<DealStage,string> {
        {DealStage.Prospecting,"#aaa"},{DealStage.Qualification,"#4a9eff"},
        {DealStage.Proposal,"var(--sa-gold)"},{DealStage.Negotiation,"#ff8c00"},
        {DealStage.ClosedWon,"#00d46a"},{DealStage.ClosedLost,"#ff6b6b"}
    };
}

<div class="crm-page-header">
    <div>
        <h1 class="crm-page-title"><i class="fa-solid fa-handshake me-2 text-gold"></i>Deals Pipeline</h1>
        <div class="crm-page-subtitle">
            @Model.Count(d => d.Stage != DealStage.ClosedWon && d.Stage != DealStage.ClosedLost) open deals ·
            Pipeline: <span class="text-gold">R@((Model.Where(d=>d.Stage!=DealStage.ClosedLost).Sum(d=>d.Value)/1000000m).ToString("0.00"))M</span> ·
            Won this period: <span style="color:#00d46a;">R@((Model.Where(d=>d.Stage==DealStage.ClosedWon).Sum(d=>d.Value)/1000m).ToString("N0"))k</span>
        </div>
    </div>
    <div class="d-flex gap-2">
        <button id="btnKanban" onclick="toggleView('kanban')" class="btn-crm btn-crm-primary"><i class="fa-solid fa-table-columns"></i> Kanban</button>
        <button id="btnList" onclick="toggleView('list')" class="btn-crm btn-crm-outline"><i class="fa-solid fa-list"></i> List</button>
        <button class="btn-crm btn-crm-primary"><i class="fa-solid fa-plus"></i> New Deal</button>
    </div>
</div>

<!-- KANBAN VIEW -->
<div id="kanbanView">
    <div class="pipeline-board">
        @foreach (var stage in stages)
        {
            var stageDeals = Model.Where(d => d.Stage == stage).ToList();
            var stageValue = stageDeals.Sum(d => d.Value);
            var stageClass = stage switch {
                DealStage.Prospecting=>"stage-prospecting", DealStage.Qualification=>"stage-qualification",
                DealStage.Proposal=>"stage-proposal", DealStage.Negotiation=>"stage-negotiation",
                DealStage.ClosedWon=>"stage-won", _=>"stage-lost"
            };
            <div class="pipeline-col">
                <div class="pipeline-col-header">
                    <span class="pipeline-col-title" style="color:@stageColors[stage];">@stage</span>
                    <span class="pipeline-col-count">@stageDeals.Count</span>
                </div>
                <div style="padding:8px 12px;border-bottom:1px solid var(--border);font-size:0.75rem;color:var(--text-muted);">
                    R@(stageValue.ToString("N0"))
                </div>
                <div class="pipeline-cards">
                    @foreach (var deal in stageDeals)
                    {
                        <div class="pipeline-deal-card">
                            <div class="deal-card-title">@deal.Title</div>
                            <div class="deal-card-company">
                                <i class="fa-solid fa-building me-1" style="font-size:0.7rem;"></i>@deal.Company
                            </div>
                            <div class="prob-bar">
                                <div class="prob-fill" style="width:@deal.Probability%"></div>
                            </div>
                            <div class="deal-card-footer">
                                <span class="deal-card-value">R@((deal.Value/1000).ToString("N0"))k</span>
                                <span class="deal-card-prob">@deal.Probability% · @deal.ExpectedCloseDate.ToString("dd MMM")</span>
                            </div>
                        </div>
                    }
                    @if (!stageDeals.Any())
                    {
                        <div style="text-align:center;padding:20px;color:var(--text-muted);font-size:0.8rem;">No deals</div>
                    }
                </div>
            </div>
        }
    </div>
</div>

<!-- LIST VIEW -->
<div id="listView" style="display:none;">
    <div class="crm-table-wrapper">
        <table class="crm-table">
            <thead>
                <tr>
                    <th>Deal</th>
                    <th>Company</th>
                    <th>Sector</th>
                    <th>Stage</th>
                    <th>Value (ZAR)</th>
                    <th>Probability</th>
                    <th>Close Date</th>
                    <th>Assigned</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var deal in Model)
                {
                    var initials = string.Join("", deal.ContactName.Split(' ').Take(2).Select(n => n[0]));
                    var stageClass = deal.Stage switch {
                        DealStage.Prospecting=>"stage-prospecting",DealStage.Qualification=>"stage-qualification",
                        DealStage.Proposal=>"stage-proposal",DealStage.Negotiation=>"stage-negotiation",
                        DealStage.ClosedWon=>"stage-won",_=>"stage-lost"
                    };
                    <tr>
                        <td>
                            <div class="contact-cell">
                                <div class="contact-avatar">@initials</div>
                                <div>
                                    <div class="contact-name">@deal.Title</div>
                                    <div class="contact-company">@deal.ContactName</div>
                                </div>
                            </div>
                        </td>
                        <td style="color:rgba(255,255,255,0.7);font-size:0.85rem;">@deal.Company</td>
                        <td><span class="badge-sector">@SectorHelper.GetDisplayName(deal.Sector).Split('&')[0].Trim()</span></td>
                        <td><span class="badge-stage @stageClass">@deal.Stage</span></td>
                        <td class="value-cell">R@(deal.Value.ToString("N0"))</td>
                        <td>
                            <div style="display:flex;align-items:center;gap:8px;">
                                <div class="prob-bar" style="width:60px;"><div class="prob-fill" style="width:@deal.Probability%"></div></div>
                                <span style="font-size:0.78rem;color:var(--text-muted);">@deal.Probability%</span>
                            </div>
                        </td>
                        <td style="font-size:0.82rem;color:@(deal.ExpectedCloseDate < DateTime.Now && deal.Stage != DealStage.ClosedWon && deal.Stage != DealStage.ClosedLost ? "var(--sa-red)" : "rgba(255,255,255,0.6)");">
                            @deal.ExpectedCloseDate.ToString("dd MMM yyyy")
                        </td>
                        <td style="font-size:0.78rem;color:rgba(255,255,255,0.6);">@deal.AssignedTo</td>
                        <td>
                            <div class="table-actions">
                                <a href="#" class="btn-table-action"><i class="fa-solid fa-eye"></i></a>
                                <a href="#" class="btn-table-action"><i class="fa-solid fa-edit"></i></a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        function toggleView(view) {
            document.getElementById('kanbanView').style.display = view === 'kanban' ? 'block' : 'none';
            document.getElementById('listView').style.display = view === 'list' ? 'block' : 'none';
            document.getElementById('btnKanban').className = view === 'kanban' ? 'btn-crm btn-crm-primary' : 'btn-crm btn-crm-outline';
            document.getElementById('btnList').className = view === 'list' ? 'btn-crm btn-crm-primary' : 'btn-crm btn-crm-outline';
        }
    </script>
}
