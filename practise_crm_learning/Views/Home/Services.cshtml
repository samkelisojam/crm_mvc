@{
    ViewData["Title"] = "Features & Services";
}

<!-- PAGE HERO -->
<section class="page-hero">
    <div class="container">
        <div class="hero-badge mx-auto d-inline-flex">
            <i class="fa-solid fa-star"></i> World-Class Features
        </div>
        <h1 class="section-title mt-3">Everything Your SA Business Needs</h1>
        <p class="section-subtitle mx-auto">One platform to manage all your customer relationships, sales pipelines and business growth.</p>
    </div>
</section>

<!-- CORE CRM MODULES -->
<section class="section-base section-dark">
    <div class="container">
        <div class="text-center mb-5">
            <div class="section-label">Core CRM Modules</div>
            <h2 class="section-title">The Full UbuntuCRM Suite</h2>
        </div>

        <!-- Contacts -->
        <div class="row g-5 align-items-center mb-5">
            <div class="col-lg-6">
                <div class="section-label">Module 01</div>
                <h3 class="section-title" style="font-size:1.8rem;">Contact Management</h3>
                <p style="color:rgba(255,255,255,0.7);line-height:1.8;margin-bottom:24px;">
                    A 360° view of every customer, partner and prospect. Store contact details, interaction history, documents and notes in a single, searchable profile. Tag contacts by SA province, sector, and custom labels.
                </p>
                <ul style="list-style:none;padding:0;display:flex;flex-direction:column;gap:10px;">
                    @foreach (var f in new[] { "Full history of every interaction", "Province & sector tagging", "Duplicate detection", "CSV import/export", "Custom fields", "WhatsApp conversation logging" })
                    {
                        <li style="display:flex;gap:10px;align-items:center;color:rgba(255,255,255,0.8);font-size:0.9rem;">
                            <i class="fa-solid fa-check-circle" style="color:var(--sa-green);flex-shrink:0;"></i> @f
                        </li>
                    }
                </ul>
            </div>
            <div class="col-lg-6">
                <div class="card-dark" style="padding:28px;">
                    <div class="crm-table-wrapper">
                        <table class="crm-table" style="margin:0;">
                            <thead><tr><th>Name</th><th>Province</th><th>Type</th><th>Status</th></tr></thead>
                            <tbody>
                                @foreach (var c in new[] {
                                    new { name="Sipho Nkosi", init="SN", prov="Gauteng", type="Customer", color="green" },
                                    new { name="Ayanda Dlamini", init="AD", prov="W Cape", type="Prospect", color="blue" },
                                    new { name="Fatima Patel", init="FP", prov="KZN", type="Partner", color="gold" }
                                })
                                {
                                    <tr>
                                        <td><div class="contact-cell"><div class="contact-avatar" style="background:linear-gradient(135deg,var(--primary),var(--sa-@c.color));">@c.init</div><div><div class="contact-name">@c.name</div></div></div></td>
                                        <td style="color:var(--text-muted);font-size:0.82rem;">@c.prov</td>
                                        <td><span class="badge-status status-qualified">@c.type</span></td>
                                        <td><span class="badge-status status-won">Active</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="divider"></div>

        <!-- Leads -->
        <div class="row g-5 align-items-center mb-5 flex-row-reverse">
            <div class="col-lg-6">
                <div class="section-label">Module 02</div>
                <h3 class="section-title" style="font-size:1.8rem;">Lead Management</h3>
                <p style="color:rgba(255,255,255,0.7);line-height:1.8;margin-bottom:24px;">
                    Never lose a lead again. Capture from website forms, WhatsApp, phone calls, tenders and referrals. Score, assign and track every opportunity from first contact to qualified prospect.
                </p>
                <ul style="list-style:none;padding:0;display:flex;flex-direction:column;gap:10px;">
                    @foreach (var f in new[] { "Multi-source lead capture", "Automatic lead scoring", "Assign to team members", "Priority levels (Low to Critical)", "Lead-to-deal conversion", "Source tracking & attribution" })
                    {
                        <li style="display:flex;gap:10px;align-items:center;color:rgba(255,255,255,0.8);font-size:0.9rem;">
                            <i class="fa-solid fa-check-circle" style="color:var(--sa-green);flex-shrink:0;"></i> @f
                        </li>
                    }
                </ul>
            </div>
            <div class="col-lg-6">
                <div class="card-dark" style="padding:28px;">
                    <div class="d-flex flex-column gap-2">
                        @foreach (var lead in new[] {
                            new { title="Fleet Contract – 50 Vehicles", company="SA Taxi Assoc", status="status-qualified", val="R850k", priority="priority-critical" },
                            new { title="Government Tender Enquiry", company="City of CT", status="status-proposal", val="R1.2M", priority="priority-high" },
                            new { title="Real Estate Portal Setup", company="Cape Coastal", status="status-new", val="R340k", priority="priority-medium" }
                        })
                        {
                            <div class="pipeline-deal-card">
                                <div class="deal-card-title">@lead.title</div>
                                <div class="deal-card-company">@lead.company</div>
                                <div class="d-flex gap-2">
                                    <span class="badge-status @lead.status">Lead</span>
                                    <span class="badge-priority @lead.priority">Priority</span>
                                    <span class="ms-auto" style="color:var(--sa-gold);font-weight:700;font-size:0.82rem;">@lead.val</span>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="divider"></div>

        <!-- Deals Pipeline -->
        <div class="row g-5 align-items-center">
            <div class="col-lg-6">
                <div class="section-label">Module 03</div>
                <h3 class="section-title" style="font-size:1.8rem;">Sales Pipeline</h3>
                <p style="color:rgba(255,255,255,0.7);line-height:1.8;margin-bottom:24px;">
                    Visual Kanban board with drag-and-drop simplicity. Set deal values in ZAR, assign probability percentages and forecast monthly revenue. Know exactly where every rand of pipeline sits.
                </p>
                <ul style="list-style:none;padding:0;display:flex;flex-direction:column;gap:10px;">
                    @foreach (var f in new[] { "Drag-and-drop Kanban board", "Custom deal stages", "Revenue forecasting in ZAR", "Win/loss analysis", "Team leaderboard", "Weighted pipeline calculation" })
                    {
                        <li style="display:flex;gap:10px;align-items:center;color:rgba(255,255,255,0.8);font-size:0.9rem;">
                            <i class="fa-solid fa-check-circle" style="color:var(--sa-green);flex-shrink:0;"></i> @f
                        </li>
                    }
                </ul>
            </div>
            <div class="col-lg-6">
                <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:10px;">
                    @foreach (var stage in new[] {
                        new { title="Qualification", count="4", total="R3.1M" },
                        new { title="Proposal", count="6", total="R2.4M" },
                        new { title="Negotiation", count="3", total="R1.8M" }
                    })
                    {
                        <div class="card-dark" style="padding:16px;">
                            <div style="font-weight:700;font-size:0.8rem;color:rgba(255,255,255,0.8);margin-bottom:10px;">@stage.title</div>
                            <div style="font-size:1.4rem;font-weight:900;color:var(--sa-gold);">@stage.total</div>
                            <div style="font-size:0.72rem;color:var(--text-muted);margin-top:4px;">@stage.count deals</div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</section>

<!-- SA-SPECIFIC FEATURES -->
<section class="section-base section-alt">
    <div class="container">
        <div class="text-center mb-5">
            <div class="section-label">Made for South Africa</div>
            <h2 class="section-title">SA-Specific Features No Other CRM Offers</h2>
        </div>
        <div class="row g-4">
            @{
                var saFeatures = new[]
                {
                    new { icon="fa-shield-halved", color="green", title="POPIA Compliance Suite", desc="Full POPIA compliance tools: data subject access requests, consent management, data breach notification workflows, and Information Officer dashboard." },
                    new { icon="fa-chart-bar", color="gold", title="B-BBEE Reporting Module", desc="Track B-BBEE scorecards, supplier development spend, enterprise development activities and skills development contributions automatically." },
                    new { icon="fa-building", color="blue", title="CIPC Integration", desc="Verify any SA company registration directly from the CRM. Pull director information, registration dates, and company status from CIPC." },
                    new { icon="fa-map", color="red", title="SA Province Intelligence", desc="Tag, filter and report on contacts and deals by all 9 SA provinces. Province-level heat maps show opportunity density by region." },
                    new { icon="fa-money-bill-wave", color="purple", title="Multi-Currency (ZAR Focus)", desc="All reporting in ZAR by default. Support for USD, EUR, GBP for international deals. SARS exchange rate integration for tax reporting." },
                    new { icon="fa-file-lines", color="teal", title="SA Tender Tracker", desc="Track government tenders from etenders.gov.za, sync directly to your CRM pipeline and assign to sales reps with deadline reminders." },
                };
                foreach (var f in saFeatures) {
                    <div class="col-md-6 col-lg-4">
                        <div class="card-dark feature-card">
                            <div class="feature-icon @f.color"><i class="fa-solid @f.icon"></i></div>
                            <h5>@f.title</h5>
                            <p>@f.desc</p>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</section>

<!-- INTEGRATIONS -->
<section class="section-base section-dark">
    <div class="container">
        <div class="text-center mb-5">
            <div class="section-label">Integrations</div>
            <h2 class="section-title">Connects with Tools You Already Use</h2>
        </div>
        <div class="row g-3 justify-content-center">
            @foreach (var tool in new[] { "WhatsApp Business", "Gmail / Outlook", "Xero / Sage SA", "Peach Payments", "Ozow", "SMSPortal SA", "Slack", "Microsoft Teams", "Zapier", "Google Maps SA", "DocuSign", "Dropbox" })
            {
                <div class="col-auto">
                    <div style="background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:12px 20px;font-size:0.82rem;font-weight:600;color:rgba(255,255,255,0.7);">
                        <i class="fa-solid fa-plug me-2" style="color:var(--sa-gold);"></i>@tool
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- CTA -->
<section class="section-base section-alt">
    <div class="container">
        <div class="cta-banner">
            <h2>Start Your Free Trial Today</h2>
            <p>All features. No credit card. Register in 5 minutes.</p>
            <div class="d-flex justify-content-center gap-3 flex-wrap">
                <a asp-controller="Company" asp-action="Register" class="btn-hero-primary">
                    <i class="fa-solid fa-rocket"></i> Start Free
                </a>
                <a asp-controller="Home" asp-action="Pricing" class="btn-hero-secondary">
                    <i class="fa-solid fa-tag"></i> View Pricing
                </a>
            </div>
        </div>
    </div>
</section>
