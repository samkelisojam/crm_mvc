@{
    ViewData["Title"] = "About Us";
}

<!-- PAGE HERO -->
<section class="page-hero">
    <div class="container">
        <div class="hero-badge mx-auto d-inline-flex">
            <i class="fa-solid fa-leaf"></i> Our Story
        </div>
        <h1 class="section-title mt-3">About UbuntuCRM</h1>
        <p class="section-subtitle mx-auto mt-2">"Umuntu Ngumuntu Ngabantu" — I am because we are. Built in South Africa, for South Africa, with African values at our core.</p>
    </div>
</section>

<!-- MISSION -->
<section class="section-base section-dark">
    <div class="container">
        <div class="row g-5 align-items-center">
            <div class="col-lg-6">
                <div class="section-label">Our Mission</div>
                <h2 class="section-title">Empowering South African Business at Every Level</h2>
                <p style="color:rgba(255,255,255,0.7);font-size:1rem;line-height:1.8;margin-bottom:24px;">
                    UbuntuCRM was born in Johannesburg in 2021 with a simple but powerful vision: to give South African entrepreneurs and enterprises the same CRM tools that global giants use — but designed specifically for our market, our regulations, and our culture.
                </p>
                <p style="color:rgba(255,255,255,0.6);font-size:0.95rem;line-height:1.8;margin-bottom:32px;">
                    From a car wash owner in Soweto tracking his 200 monthly fleet clients, to a mining company in Rustenburg managing procurement relationships across 14 provinces — UbuntuCRM is the platform built for South African scale.
                </p>
                <div class="sa-flag-bar" style="width:120px;"></div>
            </div>
            <div class="col-lg-6">
                <div class="row g-3">
                    <div class="col-6">
                        <div class="stat-highlight">
                            <div class="stat-highlight-value">2021</div>
                            <div class="stat-highlight-label">Founded in Johannesburg</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="stat-highlight">
                            <div class="stat-highlight-value">5,200+</div>
                            <div class="stat-highlight-label">SA Companies Registered</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="stat-highlight">
                            <div class="stat-highlight-value">9</div>
                            <div class="stat-highlight-label">SA Provinces Covered</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="stat-highlight">
                            <div class="stat-highlight-value">14</div>
                            <div class="stat-highlight-label">Industry Verticals</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="stat-highlight">
                            <div class="stat-highlight-value">R2.4B+</div>
                            <div class="stat-highlight-label">Deals Tracked</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="stat-highlight">
                            <div class="stat-highlight-value">99.9%</div>
                            <div class="stat-highlight-label">Platform Uptime</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- VALUES -->
<section class="section-base section-alt">
    <div class="container">
        <div class="text-center mb-5">
            <div class="section-label">What Drives Us</div>
            <h2 class="section-title">Our Core Values</h2>
        </div>
        <div class="row g-4">
            @{
                var values = new[]
                {
                    new { icon="fa-handshake", color="gold", title="Ubuntu", desc="Community is everything. We build products that bring people and businesses together, reflecting South Africa's spirit of shared humanity." },
                    new { icon="fa-shield-halved", color="green", title="Trust", desc="Your customer data is sacred. POPIA compliance, bank-grade encryption, and transparent data practices — trust is non-negotiable." },
                    new { icon="fa-bolt", color="blue", title="Excellence", desc="World-class quality at every touchpoint. We refuse to accept 'good enough' — South African businesses deserve the very best." },
                    new { icon="fa-seedling", color="red", title="Growth", desc="Every feature we build is measured by one question: does this help South African businesses grow? If not, we don't ship it." },
                    new { icon="fa-globe-africa", color="purple", title="Africa First", desc="We're not adapting a foreign product. UbuntuCRM is natively built for Africa — our currencies, our regulations, our culture." },
                    new { icon="fa-people-group", color="teal", title="Inclusion", desc="From SMMEs in townships to JSE-listed corporations — UbuntuCRM is for every South African business, regardless of size." }
                };
                foreach (var v in values)
                {
                    <div class="col-md-6 col-lg-4">
                        <div class="card-dark feature-card">
                            <div class="feature-icon @v.color"><i class="fa-solid @v.icon"></i></div>
                            <h5>@v.title</h5>
                            <p>@v.desc</p>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</section>

<!-- LEADERSHIP TEAM -->
<section class="section-base section-dark">
    <div class="container">
        <div class="text-center mb-5">
            <div class="section-label">Leadership</div>
            <h2 class="section-title">The People Behind UbuntuCRM</h2>
        </div>
        <div class="row g-4">
            <div class="col-md-6 col-lg-3">
                <div class="team-card">
                    <div class="team-avatar">TN</div>
                    <div class="team-name">Thabo Nkosi</div>
                    <div class="team-role">CEO & Co-Founder</div>
                    <div class="team-bio">Former McKinsey consultant turned entrepreneur. Built 3 successful SA startups before UbuntuCRM. Passionate about township economy empowerment.</div>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="team-card">
                    <div class="team-avatar">AV</div>
                    <div class="team-name">Ayanda van Zyl</div>
                    <div class="team-role">CTO & Co-Founder</div>
                    <div class="team-bio">15 years building enterprise software. Ex-Standard Bank CTO office. PhD in Computer Science, UCT. Leads our world-class engineering team of 40.</div>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="team-card">
                    <div class="team-avatar">NM</div>
                    <div class="team-name">Nomsa Mkhize</div>
                    <div class="team-role">Chief Revenue Officer</div>
                    <div class="team-bio">Former Salesforce Africa sales director. Grew our revenue from R500k to R24M in 3 years. Believes every South African business deserves world-class tools.</div>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="team-card">
                    <div class="team-avatar">LD</div>
                    <div class="team-name">Lindiwe Dube</div>
                    <div class="team-role">Chief Product Officer</div>
                    <div class="team-bio">Product visionary who spent 10 years listening to South African businesses. Designed the SA-specific features like POPIA tools and B-BBEE reporting.</div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- SA OFFICES -->
<section class="section-base section-alt">
    <div class="container">
        <div class="text-center mb-5">
            <div class="section-label">Where We Are</div>
            <h2 class="section-title">Our South African Offices</h2>
        </div>
        <div class="row g-4">
            @{
                var offices = new[]
                {
                    new { city="Johannesburg", province="Gauteng", address="1 Sandton Drive, Sandton, 2196", phone="+27 10 100 2026", primary=true },
                    new { city="Cape Town", province="Western Cape", address="12 Bree Street, Cape Town CBD, 8001", phone="+27 21 200 3045", primary=false },
                    new { city="Durban", province="KwaZulu-Natal", address="45 Florida Road, Morningside, 4001", phone="+27 31 300 4055", primary=false },
                };
                foreach (var o in offices)
                {
                    <div class="col-md-4">
                        <div class="card-dark" style="padding:28px;">
                            <div class="d-flex align-items-center gap-3 mb-3">
                                <div class="feature-icon @(o.primary ? "gold" : "green")" style="margin-bottom:0;flex-shrink:0;"><i class="fa-solid fa-location-dot"></i></div>
                                <div>
                                    <div style="font-weight:700;color:#fff;font-size:1rem;">@o.city</div>
                                    <div style="font-size:0.8rem;color:var(--text-muted);">@o.province @(o.primary ? "· HQ" : "")</div>
                                </div>
                            </div>
                            <div class="info-row"><span class="info-row-label">Address</span><span class="info-row-value">@o.address</span></div>
                            <div class="info-row"><span class="info-row-label">Phone</span><span class="info-row-value">@o.phone</span></div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</section>

<!-- CTA -->
<section class="section-base section-dark">
    <div class="container">
        <div class="cta-banner">
            <h2>Join Our Growing SA Community</h2>
            <p>5,200+ businesses and counting. Start your journey today.</p>
            <a asp-controller="Company" asp-action="Register" class="btn-hero-primary">
                <i class="fa-solid fa-rocket"></i> Register Your Company Free
            </a>
        </div>
    </div>
</section>
