@using practise_crm_learning.Models
@model ContactPageModel
@{
    ViewData["Title"] = "Contact Us";
}

<!-- PAGE HERO -->
<section class="page-hero">
    <div class="container">
        <div class="hero-badge mx-auto d-inline-flex">
            <i class="fa-solid fa-envelope"></i> Get in Touch
        </div>
        <h1 class="section-title mt-3">Contact UbuntuCRM</h1>
        <p class="section-subtitle mx-auto">Our SA-based team is ready to help. Talk to a human — not a chatbot.</p>
    </div>
</section>

<!-- CONTACT CONTENT -->
<section class="section-base section-dark">
    <div class="container">
        <div class="row g-5">

            <!-- INFO COLUMN -->
            <div class="col-lg-4">
                <div class="contact-card">
                    <h4 style="color:#fff;font-weight:700;margin-bottom:24px;">How to Reach Us</h4>

                    <div class="contact-info-item">
                        <div class="contact-info-icon"><i class="fa-solid fa-phone"></i></div>
                        <div>
                            <div class="contact-info-label">Phone (SA)</div>
                            <div class="contact-info-value">+27 10 100 2026</div>
                        </div>
                    </div>
                    <div class="contact-info-item">
                        <div class="contact-info-icon"><i class="fa-brands fa-whatsapp"></i></div>
                        <div>
                            <div class="contact-info-label">WhatsApp</div>
                            <div class="contact-info-value">+27 82 100 2026</div>
                        </div>
                    </div>
                    <div class="contact-info-item">
                        <div class="contact-info-icon"><i class="fa-solid fa-envelope"></i></div>
                        <div>
                            <div class="contact-info-label">Email</div>
                            <div class="contact-info-value">hello@ubuntucrm.co.za</div>
                        </div>
                    </div>
                    <div class="contact-info-item">
                        <div class="contact-info-icon"><i class="fa-solid fa-location-dot"></i></div>
                        <div>
                            <div class="contact-info-label">Head Office</div>
                            <div class="contact-info-value">1 Sandton Drive<br>Sandton, Johannesburg 2196</div>
                        </div>
                    </div>
                    <div class="contact-info-item">
                        <div class="contact-info-icon"><i class="fa-solid fa-clock"></i></div>
                        <div>
                            <div class="contact-info-label">Business Hours (SAST)</div>
                            <div class="contact-info-value">Mon–Fri: 08:00–18:00<br>Sat: 09:00–13:00</div>
                        </div>
                    </div>

                    <div class="divider"></div>

                    <h6 style="color:#fff;font-weight:700;margin-bottom:16px;">Our Offices</h6>
                    @{
                        var offices = new[] {
                            new { city="Johannesburg", province="Gauteng (HQ)" },
                            new { city="Cape Town", province="Western Cape" },
                            new { city="Durban", province="KwaZulu-Natal" }
                        };
                    }
                    @foreach (var o in offices)
                    {
                        <div class="d-flex gap-2 align-items-center mb-2">
                            <i class="fa-solid fa-building" style="color:var(--sa-gold);width:16px;"></i>
                            <span style="font-size:0.88rem;color:rgba(255,255,255,0.7);">@o.city <span style="color:var(--text-muted);">· @o.province</span></span>
                        </div>
                    }

                    <div class="divider"></div>
                    <div class="sa-flag-bar"></div>
                </div>
            </div>

            <!-- FORM COLUMN -->
            <div class="col-lg-8">
                @if (Model.MessageSent)
                {
                    <div style="background:rgba(0,122,77,0.15);border:1px solid rgba(0,122,77,0.4);border-radius:var(--radius-lg);padding:48px;text-align:center;">
                        <div style="width:72px;height:72px;background:rgba(0,122,77,0.2);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 20px;font-size:2rem;color:var(--sa-green);">
                            <i class="fa-solid fa-circle-check"></i>
                        </div>
                        <h4 style="color:#fff;font-weight:700;margin-bottom:10px;">Message Sent Successfully!</h4>
                        <p style="color:rgba(255,255,255,0.7);">Thank you, <strong>@Model.Name</strong>! One of our SA-based consultants will respond within 24 hours.</p>
                        <a asp-controller="Home" asp-action="Index" class="btn-hero-primary d-inline-flex mt-4">
                            <i class="fa-solid fa-home"></i> Back to Home
                        </a>
                    </div>
                }
                else
                {
                    <div class="form-dark">
                        <h4 style="color:#fff;font-weight:700;margin-bottom:8px;">Send Us a Message</h4>
                        <p style="color:var(--text-muted);font-size:0.88rem;margin-bottom:28px;">Tell us about your business and we'll get back to you with a personalised solution.</p>

                        <form asp-controller="Home" asp-action="Contact" method="post">
                            <div class="row g-3">
                                <div class="col-md-6 form-group-dark">
                                    <label class="form-label">Full Name *</label>
                                    <input asp-for="Name" class="form-control" placeholder="e.g. Sipho Nkosi" required />
                                </div>
                                <div class="col-md-6 form-group-dark">
                                    <label class="form-label">Email Address *</label>
                                    <input asp-for="Email" type="email" class="form-control" placeholder="sipho@yourcompany.co.za" required />
                                </div>
                                <div class="col-md-6 form-group-dark">
                                    <label class="form-label">Phone Number</label>
                                    <input asp-for="Phone" class="form-control" placeholder="+27 11 000 1234" />
                                </div>
                                <div class="col-md-6 form-group-dark">
                                    <label class="form-label">Company Name</label>
                                    <input asp-for="Company" class="form-control" placeholder="Your Business Name" />
                                </div>
                                <div class="col-md-6 form-group-dark">
                                    <label class="form-label">Province</label>
                                    <select asp-for="Province" class="form-select">
                                        <option value="">Select your province</option>
                                        @foreach (var p in CompanyRegisterViewModel.SAProvinces)
                                        {
                                            <option value="@p">@p</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-md-6 form-group-dark">
                                    <label class="form-label">Subject *</label>
                                    <select asp-for="Subject" class="form-select" required>
                                        <option value="">Select a subject</option>
                                        <option>Sales Enquiry – Pricing & Plans</option>
                                        <option>Technical Support</option>
                                        <option>Partnership / Reseller</option>
                                        <option>Enterprise Demo Request</option>
                                        <option>Billing Query</option>
                                        <option>Feature Request</option>
                                        <option>Other</option>
                                    </select>
                                </div>
                                <div class="col-12 form-group-dark">
                                    <label class="form-label">Message *</label>
                                    <textarea asp-for="Message" class="form-control" rows="5" placeholder="Tell us about your business, your sector, and what you're looking to achieve with CRM..." required></textarea>
                                </div>
                            </div>
                            <div class="mt-4 d-flex gap-3 flex-wrap align-items-center">
                                <button type="submit" class="btn-crm btn-crm-primary" style="padding:13px 32px;font-size:0.95rem;">
                                    <i class="fa-solid fa-paper-plane"></i> Send Message
                                </button>
                                <span style="font-size:0.78rem;color:var(--text-muted);">
                                    <i class="fa-solid fa-shield-halved me-1 text-success"></i> Your data is protected under POPIA
                                </span>
                            </div>
                        </form>
                    </div>
                }
            </div>
        </div>
    </div>
</section>
