@using practise_crm_learning.Models
@model List<Lead>
@{
    ViewData["Title"] = "Leads";
    var totalValue = Model.Sum(l => l.EstimatedValue);
    var wonCount = Model.Count(l => l.Status == LeadStatus.Won);
}

<div class="crm-page-header">
    <div>
        <h1 class="crm-page-title"><i class="fa-solid fa-bullseye me-2 text-gold"></i>Leads</h1>
        <div class="crm-page-subtitle">@Model.Count leads · Total estimated value: <span class="text-gold">R@((totalValue/1000000m).ToString("0.00"))M</span></div>
    </div>
    <div class="d-flex gap-2">
        <button class="btn-crm btn-crm-outline"><i class="fa-solid fa-filter"></i> Filters</button>
        <button class="btn-crm btn-crm-primary"><i class="fa-solid fa-plus"></i> New Lead</button>
    </div>
</div>

<!-- LEAD STATS -->
<div class="metric-grid" style="grid-template-columns:repeat(auto-fill,minmax(160px,1fr));margin-bottom:24px;">
    @{
        var statusGroups = Model.GroupBy(l => l.Status);
        var statusColors = new Dictionary<LeadStatus, string> {
            {LeadStatus.New,"status-new"},{LeadStatus.Contacted,"status-contacted"},
            {LeadStatus.Qualified,"status-qualified"},{LeadStatus.Proposal,"status-proposal"},
            {LeadStatus.Negotiation,"status-negotiation"},{LeadStatus.Won,"status-won"},{LeadStatus.Lost,"status-lost"}
        };
    }
    @foreach (var group in statusGroups)
    {
        <div class="metric-card" style="padding:16px;">
            <div class="metric-value" style="font-size:1.5rem;">@group.Count()</div>
            <div style="margin-top:4px;"><span class="badge-status @statusColors[group.Key]">@group.Key</span></div>
        </div>
    }
</div>

<!-- TOOLBAR -->
<div class="crm-toolbar">
    <div class="crm-toolbar-left">
        <div class="crm-search-inline">
            <i class="fa-solid fa-search"></i>
            <input type="text" placeholder="Search leads..." id="leadSearch" onkeyup="filterLeads()" />
        </div>
        <select class="form-select" style="background:var(--surface);border:1px solid var(--border);color:#fff;border-radius:8px;padding:8px 14px;font-size:0.85rem;width:auto;">
            <option>All Sectors</option>
            @foreach (var s in Enum.GetValues<Sector>())
            { <option>@SectorHelper.GetDisplayName(s)</option> }
        </select>
        <select class="form-select" style="background:var(--surface);border:1px solid var(--border);color:#fff;border-radius:8px;padding:8px 14px;font-size:0.85rem;width:auto;">
            <option>All Priorities</option>
            @foreach (var p in Enum.GetValues<Priority>()) { <option>@p</option> }
        </select>
    </div>
    <div style="font-size:0.82rem;color:var(--text-muted);">@Model.Count leads</div>
</div>

<!-- TABLE -->
<div class="crm-table-wrapper">
    <table class="crm-table" id="leadsTable">
        <thead>
            <tr>
                <th><input type="checkbox" class="form-check-input" /></th>
                <th>Lead Title</th>
                <th>Contact / Company</th>
                <th>Sector</th>
                <th>Status</th>
                <th>Priority</th>
                <th>Value (ZAR)</th>
                <th>Source</th>
                <th>Assigned To</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var lead in Model)
            {
                var initials = string.Join("", lead.ContactName.Split(' ').Take(2).Select(n => n[0]));
                var statusClass = lead.Status switch {
                    LeadStatus.New=>"status-new", LeadStatus.Contacted=>"status-contacted", LeadStatus.Qualified=>"status-qualified",
                    LeadStatus.Proposal=>"status-proposal", LeadStatus.Negotiation=>"status-negotiation",
                    LeadStatus.Won=>"status-won", _=>"status-lost"
                };
                var prioClass = lead.Priority switch { Priority.Low=>"priority-low", Priority.Medium=>"priority-medium", Priority.High=>"priority-high", _=>"priority-critical" };
                <tr>
                    <td><input type="checkbox" class="form-check-input" /></td>
                    <td>
                        <div style="font-weight:600;color:#fff;font-size:0.88rem;max-width:220px;">@lead.Title</div>
                        <div style="font-size:0.75rem;color:var(--text-muted);">Created @lead.CreatedAt.ToString("dd MMM")</div>
                    </td>
                    <td>
                        <div class="contact-cell">
                            <div class="contact-avatar">@initials</div>
                            <div>
                                <div class="contact-name">@lead.ContactName</div>
                                <div class="contact-company">@lead.Company</div>
                            </div>
                        </div>
                    </td>
                    <td><span class="badge-sector" style="font-size:0.7rem;">@SectorHelper.GetDisplayName(lead.Sector).Split('&')[0].Trim()</span></td>
                    <td><span class="badge-status @statusClass">@lead.Status</span></td>
                    <td><span class="badge-priority @prioClass">@lead.Priority</span></td>
                    <td class="value-cell">R@(lead.EstimatedValue.ToString("N0"))</td>
                    <td style="font-size:0.78rem;color:rgba(255,255,255,0.6);">@lead.Source</td>
                    <td>
                        <span style="background:rgba(255,255,255,0.07);padding:3px 10px;border-radius:50px;font-size:0.75rem;color:rgba(255,255,255,0.7);">@lead.AssignedTo</span>
                    </td>
                    <td>
                        <div class="table-actions">
                            <a href="#" class="btn-table-action"><i class="fa-solid fa-eye"></i></a>
                            <a href="#" class="btn-table-action btn-crm-success" style="color:#00d46a;border-color:rgba(0,122,77,0.4);">Convert</a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        function filterLeads() {
            const val = document.getElementById('leadSearch').value.toLowerCase();
            document.querySelectorAll('#leadsTable tbody tr').forEach(row => {
                row.style.display = row.textContent.toLowerCase().includes(val) ? '' : 'none';
            });
        }
    </script>
}
