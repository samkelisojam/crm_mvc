@using practise_crm_learning.Models
@model DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="crm-page-header">
    <div>
        <h1 class="crm-page-title">Good Morning, Thabo 👋</h1>
        <div class="crm-page-subtitle">@Model.CompanyName · @SectorHelper.GetDisplayName(Model.CompanySector) · Wednesday, 18 March 2026</div>
    </div>
    <div class="d-flex gap-2">
        <a asp-controller="Crm" asp-action="Leads" class="btn-crm btn-crm-outline"><i class="fa-solid fa-plus"></i> Add Lead</a>
        <a asp-controller="Crm" asp-action="Deals" class="btn-crm btn-crm-primary"><i class="fa-solid fa-handshake"></i> New Deal</a>
    </div>
</div>

<!-- METRICS -->
<div class="metric-grid">
    <div class="metric-card">
        <div class="metric-card-icon" style="background:rgba(255,182,18,0.15);color:var(--sa-gold);"><i class="fa-solid fa-users"></i></div>
        <div class="metric-value">@Model.TotalContacts.ToString("N0")</div>
        <div class="metric-label">Total Contacts</div>
        <div class="metric-change positive"><i class="fa-solid fa-arrow-trend-up me-1"></i>+23 this week</div>
    </div>
    <div class="metric-card">
        <div class="metric-card-icon" style="background:rgba(74,158,255,0.15);color:#4a9eff;"><i class="fa-solid fa-bullseye"></i></div>
        <div class="metric-value">@Model.TotalLeads</div>
        <div class="metric-label">Active Leads</div>
        <div class="metric-change positive"><i class="fa-solid fa-arrow-trend-up me-1"></i>+@Model.NewLeadsThisWeek this week</div>
    </div>
    <div class="metric-card">
        <div class="metric-card-icon" style="background:rgba(0,122,77,0.2);color:#00d46a;"><i class="fa-solid fa-handshake"></i></div>
        <div class="metric-value">@Model.TotalDeals</div>
        <div class="metric-label">Open Deals</div>
        <div class="metric-change positive"><i class="fa-solid fa-arrow-trend-up me-1"></i>@Model.WonDealsThisMonth won this month</div>
    </div>
    <div class="metric-card">
        <div class="metric-card-icon" style="background:rgba(255,182,18,0.2);color:var(--sa-gold);"><i class="fa-solid fa-sack-dollar"></i></div>
        <div class="metric-value">R@((Model.TotalPipelineValue / 1000000).ToString("0.0"))M</div>
        <div class="metric-label">Pipeline Value</div>
        <div class="metric-change positive"><i class="fa-solid fa-arrow-trend-up me-1"></i>+@Model.RevenueGrowth% growth</div>
    </div>
    <div class="metric-card">
        <div class="metric-card-icon" style="background:rgba(222,56,49,0.15);color:#ff6b6b;"><i class="fa-solid fa-calendar-check"></i></div>
        <div class="metric-value">@Model.OpenActivities</div>
        <div class="metric-label">Open Activities</div>
        <div class="metric-change positive"><i class="fa-solid fa-clock me-1"></i>4 due today</div>
    </div>
    <div class="metric-card">
        <div class="metric-card-icon" style="background:rgba(0,122,77,0.2);color:var(--sa-green);"><i class="fa-solid fa-chart-line"></i></div>
        <div class="metric-value">R@((Model.RevenueThisMonth / 1000000).ToString("0.00"))M</div>
        <div class="metric-label">Revenue This Month</div>
        <div class="metric-change positive"><i class="fa-solid fa-arrow-trend-up me-1"></i>+@Model.RevenueGrowth% vs last month</div>
    </div>
</div>

<!-- MAIN CONTENT ROW -->
<div class="row g-4 mb-4">

    <!-- RECENT LEADS -->
    <div class="col-lg-7">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;">
            <div style="font-weight:700;color:#fff;font-size:1rem;"><i class="fa-solid fa-bullseye me-2 text-gold"></i>Recent Leads</div>
            <a asp-controller="Crm" asp-action="Leads" class="btn-table-action">View all <i class="fa-solid fa-arrow-right ms-1"></i></a>
        </div>
        <div class="crm-table-wrapper">
            <table class="crm-table">
                <thead>
                    <tr><th>Lead</th><th>Sector</th><th>Status</th><th>Value</th><th>Priority</th></tr>
                </thead>
                <tbody>
                    @foreach (var lead in Model.RecentLeads)
                    {
                        var initials = string.Join("", lead.ContactName.Split(' ').Take(2).Select(n => n[0]));
                        <tr>
                            <td>
                                <div class="contact-cell">
                                    <div class="contact-avatar">@initials</div>
                                    <div>
                                        <div class="contact-name">@lead.Title</div>
                                        <div class="contact-company">@lead.ContactName · @lead.Company</div>
                                    </div>
                                </div>
                            </td>
                            <td><span class="badge-sector">@SectorHelper.GetDisplayName(lead.Sector).Split('&')[0].Trim()</span></td>
                            <td><span class="badge-status status-@lead.Status.ToString().ToLower()">@lead.Status</span></td>
                            <td class="value-cell">R@((lead.EstimatedValue / 1000).ToString("N0"))k</td>
                            <td><span class="badge-priority priority-@lead.Priority.ToString().ToLower()">@lead.Priority</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- UPCOMING ACTIVITIES -->
    <div class="col-lg-5">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;">
            <div style="font-weight:700;color:#fff;font-size:1rem;"><i class="fa-solid fa-calendar-check me-2 text-gold"></i>Today's Activities</div>
            <a asp-controller="Crm" asp-action="Activities" class="btn-table-action">View all <i class="fa-solid fa-arrow-right ms-1"></i></a>
        </div>
        @foreach (var act in Model.UpcomingActivities)
        {
            var typeClass = act.Type switch { "Call" => "act-call", "Email" => "act-email", "Meeting" => "act-meeting", _ => "act-task" };
            var typeIcon = act.Type switch { "Call" => "fa-phone", "Email" => "fa-envelope", "Meeting" => "fa-people-arrows", _ => "fa-list-check" };
            <div class="activity-item">
                <div class="activity-icon @typeClass"><i class="fa-solid @typeIcon"></i></div>
                <div style="flex:1;">
                    <div class="activity-title">@act.Title</div>
                    <div class="activity-meta">
                        <i class="fa-solid fa-building me-1"></i>@act.RelatedTo &nbsp;·&nbsp;
                        <i class="fa-solid fa-user me-1"></i>@act.AssignedTo &nbsp;·&nbsp;
                        <span class="badge-priority priority-@act.Priority.ToString().ToLower()">@act.Priority</span>
                    </div>
                </div>
                <button class="btn-table-action" style="flex-shrink:0;"><i class="fa-solid fa-check"></i></button>
            </div>
        }
    </div>
</div>

<!-- SECOND ROW -->
<div class="row g-4">

    <!-- ACTIVE DEALS -->
    <div class="col-lg-8">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;">
            <div style="font-weight:700;color:#fff;font-size:1rem;"><i class="fa-solid fa-handshake me-2 text-gold"></i>Active Deals</div>
            <a asp-controller="Crm" asp-action="Deals" class="btn-table-action">View all <i class="fa-solid fa-arrow-right ms-1"></i></a>
        </div>
        <div class="crm-table-wrapper">
            <table class="crm-table">
                <thead>
                    <tr><th>Deal</th><th>Company</th><th>Stage</th><th>Value</th><th>Close Date</th></tr>
                </thead>
                <tbody>
                    @foreach (var deal in Model.ActiveDeals)
                    {
                        var initials = string.Join("", deal.ContactName.Split(' ').Take(2).Select(n => n[0]));
                        var stageClass = deal.Stage switch {
                            DealStage.Prospecting => "stage-prospecting", DealStage.Qualification => "stage-qualification",
                            DealStage.Proposal => "stage-proposal", DealStage.Negotiation => "stage-negotiation",
                            DealStage.ClosedWon => "stage-won", _ => "stage-lost"
                        };
                        <tr>
                            <td>
                                <div class="contact-cell">
                                    <div class="contact-avatar">@initials</div>
                                    <div>
                                        <div class="contact-name">@deal.Title</div>
                                        <div class="contact-company" style="display:flex;align-items:center;gap:4px;">
                                            <div class="prob-bar" style="width:60px;display:inline-block;vertical-align:middle;">
                                                <div class="prob-fill" style="width:@deal.Probability%"></div>
                                            </div>
                                            @deal.Probability% prob
                                        </div>
                                    </div>
                                </div>
                            </td>
                            <td style="color:rgba(255,255,255,0.7);font-size:0.82rem;">@deal.Company</td>
                            <td><span class="badge-stage @stageClass">@deal.Stage</span></td>
                            <td class="value-cell">R@((deal.Value / 1000).ToString("N0"))k</td>
                            <td style="font-size:0.82rem;color:@(deal.ExpectedCloseDate < DateTime.Now ? "var(--sa-red)" : "rgba(255,255,255,0.6)");">
                                @deal.ExpectedCloseDate.ToString("dd MMM")
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- CONTACTS BY PROVINCE -->
    <div class="col-lg-4">
        <div style="font-weight:700;color:#fff;font-size:1rem;margin-bottom:14px;"><i class="fa-solid fa-map-location-dot me-2 text-gold"></i>Contacts by Province</div>
        <div class="crm-table-wrapper" style="padding:4px 0;">
            @{
                var maxProv = Model.ContactsByProvince.Values.Max();
            }
            @foreach (var prov in Model.ContactsByProvince.OrderByDescending(x => x.Value))
            {
                var pct = (prov.Value * 100) / maxProv;
                <div style="padding:12px 16px;border-bottom:1px solid rgba(255,255,255,0.04);">
                    <div style="display:flex;justify-content:space-between;margin-bottom:6px;font-size:0.82rem;">
                        <span style="color:rgba(255,255,255,0.8);">@prov.Key</span>
                        <span style="color:var(--sa-gold);font-weight:700;">@prov.Value</span>
                    </div>
                    <div class="prob-bar"><div class="prob-fill" style="width:@pct%"></div></div>
                </div>
            }
        </div>
    </div>
</div>
