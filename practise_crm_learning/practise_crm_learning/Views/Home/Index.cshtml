@{
    ViewData["Title"] = "Home";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- ═══════════════ HERO ═══════════════ -->
<section class="hero-section">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <div class="hero-badge animate-in">
                    <i class="fa-solid fa-star"></i> Proudly South African · Used by 5,000+ Businesses
                </div>
                <h1 class="hero-title animate-in delay-1">
                    The Smartest CRM<br>for <span>South African</span><br>
                    <span class="sa-accent">Business Growth</span>
                </h1>
                <p class="hero-subtitle animate-in delay-2">
                    From car wash fleets in Gauteng to real estate agencies in the Western Cape — UbuntuCRM gives every South African business a world-class platform to manage customers, close deals, and scale rapidly.
                </p>
                <div class="hero-cta-group animate-in delay-3">
                    <a asp-controller="Company" asp-action="Register" class="btn-hero-primary">
                        <i class="fa-solid fa-rocket"></i> Start Free – No Credit Card
                    </a>
                    <a asp-controller="Crm" asp-action="Dashboard" class="btn-hero-secondary">
                        <i class="fa-solid fa-play-circle"></i> View Live Demo
                    </a>
                </div>
                <div class="hero-stats animate-in">
                    <div class="hero-stat">
                        <div class="hero-stat-value">5,200+</div>
                        <div class="hero-stat-label">Companies</div>
                    </div>
                    <div class="hero-stat">
                        <div class="hero-stat-value">9 Provinces</div>
                        <div class="hero-stat-label">SA Coverage</div>
                    </div>
                    <div class="hero-stat">
                        <div class="hero-stat-value">R2.4B+</div>
                        <div class="hero-stat-label">Deals Tracked</div>
                    </div>
                    <div class="hero-stat">
                        <div class="hero-stat-value">14</div>
                        <div class="hero-stat-label">Industries</div>
                    </div>
                </div>
            </div>
            <div class="col-lg-6 hero-dashboard">
                <div class="hero-mockup">
                    <div class="mockup-topbar">
                        <div class="mockup-dot dot-red"></div>
                        <div class="mockup-dot dot-yellow"></div>
                        <div class="mockup-dot dot-green"></div>
                        <span style="margin-left:12px;font-size:0.72rem;color:#8b949e;">UbuntuCRM – Dashboard</span>
                    </div>
                    <div class="mockup-body">
                        <div class="mockup-metrics">
                            <div class="mockup-metric">
                                <div class="mockup-metric-val">1,247</div>
                                <div class="mockup-metric-lbl">Contacts</div>
                            </div>
                            <div class="mockup-metric">
                                <div class="mockup-metric-val">389</div>
                                <div class="mockup-metric-lbl">Leads</div>
                            </div>
                            <div class="mockup-metric">
                                <div class="mockup-metric-val">R4.85M</div>
                                <div class="mockup-metric-lbl">Pipeline</div>
                            </div>
                            <div class="mockup-metric">
                                <div class="mockup-metric-val">+18.5%</div>
                                <div class="mockup-metric-lbl">Growth</div>
                            </div>
                        </div>
                        <div style="margin-bottom:12px;">
                            <div style="font-size:0.7rem;color:#8b949e;margin-bottom:8px;text-transform:uppercase;letter-spacing:0.7px;">Monthly Revenue (ZAR)</div>
                            <div class="mockup-bars">
                                <div class="mockup-bar" style="height:40%"></div>
                                <div class="mockup-bar" style="height:55%"></div>
                                <div class="mockup-bar" style="height:45%"></div>
                                <div class="mockup-bar" style="height:70%"></div>
                                <div class="mockup-bar" style="height:60%"></div>
                                <div class="mockup-bar" style="height:85%"></div>
                                <div class="mockup-bar" style="height:100%"></div>
                            </div>
                        </div>
                        <div style="display:flex;gap:8px;flex-wrap:wrap;">
                            <span style="background:rgba(0,122,77,0.2);color:#00d46a;font-size:0.7rem;padding:4px 10px;border-radius:50px;font-weight:700;"><i class="fa-solid fa-circle-check me-1"></i>23 Deals Won</span>
                            <span style="background:rgba(255,182,18,0.15);color:#FFB612;font-size:0.7rem;padding:4px 10px;border-radius:50px;font-weight:700;"><i class="fa-solid fa-fire me-1"></i>47 New Leads</span>
                            <span style="background:rgba(74,158,255,0.15);color:#4a9eff;font-size:0.7rem;padding:4px 10px;border-radius:50px;font-weight:700;"><i class="fa-solid fa-users me-1"></i>9 Provinces</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ═══════════════ TRUSTED LOGOS / SOCIAL PROOF ═══════════════ -->
<section class="section-base section-alt" style="padding: 48px 0;">
    <div class="container">
        <p class="text-center mb-4" style="font-size:0.8rem;text-transform:uppercase;letter-spacing:1.5px;color:var(--text-muted);">Trusted by leading South African businesses</p>
        <div class="d-flex justify-content-center align-items-center flex-wrap gap-4">
            @foreach (var brand in new[] { "SA Taxi Association", "Cape Coastal Properties", "Platinum Ridge Mining", "Durban Port Authority", "Joburg Homes", "TeachSA Academy" })
            {
                <div style="background:rgba(255,255,255,0.05);border:1px solid var(--border);border-radius:10px;padding:12px 24px;font-size:0.82rem;font-weight:600;color:rgba(255,255,255,0.4);">
                    @brand
                </div>
            }
        </div>
    </div>
</section>

<!-- ═══════════════ FEATURES ═══════════════ -->
<section class="section-base section-dark" id="features">
    <div class="container">
        <div class="text-center mb-5">
            <div class="section-label">Everything You Need</div>
            <h2 class="section-title">World-Class CRM Features<br>Built for South Africa</h2>
            <p class="section-subtitle mx-auto">Every tool a growing SA business needs — from prospecting to closing, from Limpopo to the Western Cape.</p>
        </div>
        <div class="row g-4">
            <div class="col-md-6 col-lg-4">
                <div class="card-dark feature-card">
                    <div class="feature-icon gold"><i class="fa-solid fa-users"></i></div>
                    <h5>Contact Management</h5>
                    <p>Centralise all your customers, leads and partners. Tag by province, sector and relationship type. Full contact history in one click.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="card-dark feature-card">
                    <div class="feature-icon green"><i class="fa-solid fa-funnel-dollar"></i></div>
                    <h5>Sales Pipeline</h5>
                    <p>Visual Kanban pipeline with drag-and-drop. Track deals from Prospecting to Close. Set probability and forecast revenue in ZAR.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="card-dark feature-card">
                    <div class="feature-icon blue"><i class="fa-solid fa-bullseye"></i></div>
                    <h5>Lead Management</h5>
                    <p>Capture leads from website, WhatsApp, referrals and tenders. Qualify, assign and track every opportunity automatically.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="card-dark feature-card">
                    <div class="feature-icon red"><i class="fa-solid fa-chart-line"></i></div>
                    <h5>Analytics & Reports</h5>
                    <p>Real-time dashboards with province-level insights. Revenue forecasting, team performance and sector analysis built for SA business.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="card-dark feature-card">
                    <div class="feature-icon purple"><i class="fa-brands fa-whatsapp"></i></div>
                    <h5>WhatsApp Integration</h5>
                    <p>Connect your business WhatsApp number. Auto-log conversations as CRM activities. SA's #1 communication channel, fully integrated.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="card-dark feature-card">
                    <div class="feature-icon teal"><i class="fa-solid fa-robot"></i></div>
                    <h5>AI-Powered Insights</h5>
                    <p>Smart deal scoring, next-best-action recommendations and automated follow-up reminders powered by advanced AI models.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="card-dark feature-card">
                    <div class="feature-icon gold"><i class="fa-solid fa-file-invoice-dollar"></i></div>
                    <h5>SA Compliance Tools</h5>
                    <p>POPIA-compliant data handling, B-BBEE reporting module, VAT tracking and CIPC company verification built right in.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="card-dark feature-card">
                    <div class="feature-icon green"><i class="fa-solid fa-building-user"></i></div>
                    <h5>Multi-Company Support</h5>
                    <p>Manage multiple branches or franchises from one dashboard. Enterprise-grade multi-tenancy with granular role control.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="card-dark feature-card">
                    <div class="feature-icon blue"><i class="fa-solid fa-mobile-alt"></i></div>
                    <h5>Mobile-First Design</h5>
                    <p>Full-featured mobile app for Android and iOS. Update deals from the road in Durban or log a call from a farm in the Karoo.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ═══════════════ SOUTH AFRICAN SECTORS ═══════════════ -->
