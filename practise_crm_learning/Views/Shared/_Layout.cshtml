<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] != null ? ViewData["Title"] + " | UbuntuCRM" : "UbuntuCRM – South Africa's #1 Business CRM")</title>
    <meta name="description" content="UbuntuCRM – The world-class CRM built for South African businesses. Car wash, real estate, mining, tourism and more." />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

@{
    bool isCrmPage = Context.Request.Path.StartsWithSegments("/Crm");
}

@if (isCrmPage)
{
    <!-- CRM SIDEBAR LAYOUT -->
    <div class="crm-wrapper">
        <aside class="crm-sidebar">
            <div class="crm-brand">
                <div class="crm-logo-icon"><i class="fa-solid fa-leaf"></i></div>
                <span class="crm-brand-text">Ubuntu<strong>CRM</strong></span>
            </div>
            <nav class="crm-nav">
                <div class="crm-nav-section">MAIN</div>
                <a asp-controller="Crm" asp-action="Dashboard" class="crm-nav-link @(Context.Request.Path.ToString().Contains("Dashboard") ? "active" : "")">
                    <i class="fa-solid fa-gauge-high"></i> Dashboard
                </a>
                <a asp-controller="Crm" asp-action="Contacts" class="crm-nav-link @(Context.Request.Path.ToString().Contains("Contacts") ? "active" : "")">
                    <i class="fa-solid fa-users"></i> Contacts
                </a>
                <a asp-controller="Crm" asp-action="Leads" class="crm-nav-link @(Context.Request.Path.ToString().Contains("Leads") ? "active" : "")">
                    <i class="fa-solid fa-bullseye"></i> Leads
                </a>
                <a asp-controller="Crm" asp-action="Deals" class="crm-nav-link @(Context.Request.Path.ToString().Contains("Deals") ? "active" : "")">
                    <i class="fa-solid fa-handshake"></i> Deals
                </a>
                <a asp-controller="Crm" asp-action="Activities" class="crm-nav-link @(Context.Request.Path.ToString().Contains("Activities") ? "active" : "")">
                    <i class="fa-solid fa-calendar-check"></i> Activities
                </a>
                <div class="crm-nav-section">COMPANY</div>
                <a asp-controller="Company" asp-action="Profile" class="crm-nav-link">
                    <i class="fa-solid fa-building-user"></i> My Company
                </a>
                <a asp-controller="Home" asp-action="Pricing" class="crm-nav-link">
                    <i class="fa-solid fa-crown"></i> Subscription
                </a>
                <div class="crm-nav-section">REPORTS</div>
                <a href="#" class="crm-nav-link">
                    <i class="fa-solid fa-chart-bar"></i> Analytics
                </a>
                <a href="#" class="crm-nav-link">
                    <i class="fa-solid fa-file-chart-column"></i> Reports
                </a>
                <div class="crm-nav-section">SETTINGS</div>
                <a href="#" class="crm-nav-link">
                    <i class="fa-solid fa-sliders"></i> Settings
                </a>
                <a asp-controller="Home" asp-action="Index" class="crm-nav-link mt-2">
                    <i class="fa-solid fa-arrow-right-from-bracket"></i> Back to Site
                </a>
            </nav>
            <div class="crm-sidebar-footer">
                <div class="crm-user-card">
                    <div class="crm-avatar">TM</div>
                    <div class="crm-user-info">
                        <div class="crm-user-name">Thabo Mokoena</div>
                        <div class="crm-user-role">Admin</div>
                    </div>
                </div>
                <div class="sa-flag-bar"></div>
            </div>
        </aside>
        <div class="crm-main">
            <header class="crm-topbar">
                <div class="crm-topbar-left">
                    <button class="crm-menu-toggle" id="sidebarToggle"><i class="fa-solid fa-bars"></i></button>
                    <div class="crm-search-box">
                        <i class="fa-solid fa-search"></i>
                        <input type="text" placeholder="Search contacts, deals, leads..." />
                    </div>
                </div>
                <div class="crm-topbar-right">
                    <button class="crm-topbar-btn" title="Notifications"><i class="fa-solid fa-bell"></i><span class="badge-dot"></span></button>
                    <button class="crm-topbar-btn" title="Help"><i class="fa-solid fa-circle-question"></i></button>
                    <div class="crm-topbar-company">
                        <i class="fa-solid fa-car-wash"></i> Ubuntu Motors
                    </div>
                </div>
            </header>
            <main class="crm-content">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show mx-0 mb-3" role="alert">
                        <i class="fa-solid fa-circle-check me-2"></i>@TempData["Success"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @RenderBody()
            </main>
        </div>
    </div>
}
else
{
    <!-- PUBLIC WEBSITE LAYOUT -->
    <header class="site-header" id="siteHeader">
        <nav class="navbar navbar-expand-lg">
            <div class="container">
                <a class="navbar-brand site-logo" asp-controller="Home" asp-action="Index">
                    <div class="logo-icon"><i class="fa-solid fa-leaf"></i></div>
                    Ubuntu<strong>CRM</strong>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav mx-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">Features</a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="Home" asp-action="Services"><i class="fa-solid fa-star me-2 text-warning"></i>All Features</a></li>
                                <li><a class="dropdown-item" asp-controller="Crm" asp-action="Dashboard"><i class="fa-solid fa-gauge-high me-2 text-primary"></i>CRM Dashboard</a></li>
                                <li><a class="dropdown-item" asp-controller="Crm" asp-action="Leads"><i class="fa-solid fa-bullseye me-2 text-danger"></i>Lead Management</a></li>
                                <li><a class="dropdown-item" asp-controller="Crm" asp-action="Deals"><i class="fa-solid fa-handshake me-2 text-success"></i>Deal Pipeline</a></li>
                                <li><a class="dropdown-item" asp-controller="Crm" asp-action="Contacts"><i class="fa-solid fa-users me-2 text-info"></i>Contact Management</a></li>
                            </ul>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Pricing">Pricing</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="About">About Us</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Contact">Contact</a>
                        </li>
                    </ul>
                    <div class="header-actions">
                        <a asp-controller="Crm" asp-action="Dashboard" class="btn btn-outline-light btn-sm me-2">
                            <i class="fa-solid fa-right-to-bracket me-1"></i>Login
                        </a>
                        <a asp-controller="Company" asp-action="Register" class="btn btn-sa-gold btn-sm">
                            <i class="fa-solid fa-rocket me-1"></i>Get Started Free
                        </a>
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main>
        @if (TempData["Success"] != null)
        {
            <div class="container mt-3">
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="fa-solid fa-circle-check me-2"></i>@TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            </div>
        }
        @RenderBody()
    </main>

    <footer class="site-footer">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-4">
                    <div class="footer-brand">
                        <div class="logo-icon me-2"><i class="fa-solid fa-leaf"></i></div>
                        Ubuntu<strong>CRM</strong>
                    </div>
                    <p class="footer-tagline">The world-class CRM proudly built for South African businesses. Empowering growth, one deal at a time.</p>
                    <div class="sa-flag-bar mt-3"></div>
                    <div class="footer-socials mt-3">
                        <a href="#" class="footer-social-link"><i class="fa-brands fa-linkedin"></i></a>
                        <a href="#" class="footer-social-link"><i class="fa-brands fa-twitter"></i></a>
                        <a href="#" class="footer-social-link"><i class="fa-brands fa-facebook"></i></a>
                        <a href="#" class="footer-social-link"><i class="fa-brands fa-whatsapp"></i></a>
                    </div>
                </div>
                <div class="col-lg-2 col-md-4">
                    <h6 class="footer-heading">Product</h6>
                    <ul class="footer-links">
                        <li><a asp-controller="Home" asp-action="Services">Features</a></li>
                        <li><a asp-controller="Home" asp-action="Pricing">Pricing</a></li>
                        <li><a asp-controller="Crm" asp-action="Dashboard">Dashboard</a></li>
                        <li><a href="#">API Docs</a></li>
                        <li><a href="#">Integrations</a></li>
                    </ul>
                </div>
                <div class="col-lg-2 col-md-4">
                    <h6 class="footer-heading">Company</h6>
                    <ul class="footer-links">
                        <li><a asp-controller="Home" asp-action="About">About Us</a></li>
                        <li><a asp-controller="Home" asp-action="Contact">Contact</a></li>
                        <li><a href="#">Careers</a></li>
                        <li><a href="#">Blog</a></li>
                        <li><a href="#">Partners</a></li>
                    </ul>
                </div>
                <div class="col-lg-2 col-md-4">
                    <h6 class="footer-heading">Industries</h6>
                    <ul class="footer-links">
                        <li><a href="#">Car Wash</a></li>
                        <li><a href="#">Real Estate</a></li>
                        <li><a href="#">Mining</a></li>
                        <li><a href="#">Healthcare</a></li>
                        <li><a href="#">Tourism</a></li>
                    </ul>
                </div>
                <div class="col-lg-2">
                    <h6 class="footer-heading">Contact</h6>
                    <ul class="footer-links">
                        <li><i class="fa-solid fa-location-dot me-2 text-warning"></i>Sandton, Johannesburg</li>
                        <li><i class="fa-solid fa-phone me-2 text-warning"></i>+27 10 100 2026</li>
                        <li><i class="fa-solid fa-envelope me-2 text-warning"></i>hello@ubuntucrm.co.za</li>
                    </ul>
                </div>
            </div>
            <div class="footer-bottom">
                <div>
                    &copy; 2026 UbuntuCRM (Pty) Ltd. All rights reserved. Reg. 2024/123456/07
                </div>
                <div class="footer-legal">
                    <a asp-controller="Home" asp-action="Privacy">Privacy Policy</a>
                    <a href="#">Terms of Service</a>
                    <a href="#">POPIA Compliance</a>
                </div>
            </div>
        </div>
    </footer>
}

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
