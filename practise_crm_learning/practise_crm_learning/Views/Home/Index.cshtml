<!-- ═══════════════ PRICING TEASER ═══════════════ -->
<section class="section-base section-alt">
    <div class="container">
        <div class="text-center mb-5">
            <div class="section-label">Simple Pricing</div>
            <h2 class="section-title">Plans in South African Rands</h2>
            <p class="section-subtitle mx-auto">No US dollar surprises. Pricing in ZAR, billed locally. Start free, upgrade as you grow.</p>
        </div>
        <div class="row g-4 justify-content-center">
            <div class="col-md-3">
                <div class="pricing-card text-center">
                    <div class="pricing-tier-name">Free</div>
                    <div class="pricing-price">R0<span>/mo</span></div>
                    <p class="pricing-desc">Solo entrepreneurs</p>
                    <a asp-controller="Company" asp-action="Register" class="btn-pricing btn-pricing-outline">Get Started</a>
                </div>
            </div>
            <div class="col-md-3">
                <div class="pricing-card text-center">
                    <div class="pricing-tier-name">Starter</div>
                    <div class="pricing-price">R299<span>/mo</span></div>
                    <p class="pricing-desc">Small businesses</p>
                    <a asp-controller="Company" asp-action="Register" class="btn-pricing btn-pricing-outline">Get Started</a>
                </div>
            </div>
            <div class="col-md-3">
                <div class="pricing-card popular text-center">
                    <div class="popular-badge">⭐ Most Popular</div>
                    <div class="pricing-tier-name">Professional</div>
                    <div class="pricing-price">R799<span>/mo</span></div>
                    <p class="pricing-desc">Growing businesses</p>
                    <a asp-controller="Company" asp-action="Register" class="btn-pricing btn-pricing-gold">Get Started</a>
                </div>
            </div>
            <div class="col-md-3">
                <div class="pricing-card text-center">
                    <div class="pricing-tier-name">Enterprise</div>
                    <div class="pricing-price">R2,499<span>/mo</span></div>
                    <p class="pricing-desc">Large corporations</p>
                    <a asp-controller="Home" asp-action="Contact" class="btn-pricing btn-pricing-outline">Contact Us</a>
                </div>
            </div>
        </div>
        <div class="text-center mt-4">
            <a asp-controller="Home" asp-action="Pricing" class="btn-hero-secondary" style="display:inline-flex;">
                <i class="fa-solid fa-arrow-right"></i> See Full Pricing & Compare Plans
            </a>
        </div>
    </div>
</section>

<!-- ═══════════════ CTA SECTION ═══════════════ -->
<section class="section-base section-dark">
    <div class="container">
        <div class="cta-banner">
            <div class="sa-flag-bar" style="width:80px;margin:0 auto 24px;"></div>
            <h2>Ready to Grow Your SA Business?</h2>
            <p>Join 5,200+ South African companies already using UbuntuCRM.<br>Setup takes 5 minutes. No contract. Cancel anytime.</p>
            <div class="d-flex justify-content-center gap-3 flex-wrap">
                <a asp-controller="Company" asp-action="Register" class="btn-hero-primary">
                    <i class="fa-solid fa-rocket"></i> Register Your Company Free
                </a>
                <a asp-controller="Home" asp-action="Contact" class="btn-hero-secondary">
                    <i class="fa-solid fa-phone"></i> Talk to Sales
                </a>
            </div>
        </div>
    </div>
</section>
