                    <h6>Finance</h6>
                    <small>Clients, policies, FICA</small>
                </div>
            </div>
            <div class="col-6 col-md-4 col-lg-3 col-xl-2">
                <div class="sector-card">
                    <div class="sector-icon-wrap"><i class="fa-solid fa-graduation-cap"></i></div>
                    <h6>Education</h6>
                    <small>Enrolments, training</small>
                </div>
            </div>
            <div class="col-6 col-md-4 col-lg-3 col-xl-2">
                <div class="sector-card">
                    <div class="sector-icon-wrap"><i class="fa-solid fa-seedling"></i></div>
